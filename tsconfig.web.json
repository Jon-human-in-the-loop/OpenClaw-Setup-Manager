{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/preload/**/*", "src/renderer/**/*", "src/types/**/*"],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@/*": ["src/renderer/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  }
}
